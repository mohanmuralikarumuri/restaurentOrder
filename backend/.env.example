# ─────────────────────────────────────────────
# Spice Garden Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/spicegarden
# Atlas example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/spicegarden?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────
# Use a long random string (min 32 chars) — never share this
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_32chars
JWT_EXPIRES_IN=7d

# ── Nodemailer / Gmail SMTP ──────────────────
# Use an App Password (not your main Gmail password)
# Guide: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Restaurant Owner / Chef email ───────────
OWNER_EMAIL=restaurantowner@gmail.com
RESTAURANT_NAME=Spice Garden

# ── Frontend URL (for CORS) ──────────────────
FRONTEND_URL=http://127.0.0.1:5500
